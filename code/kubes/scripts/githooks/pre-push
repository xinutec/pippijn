#!/usr/bin/env bash
# Pre-push gate: life's heavier checks that are too slow to run on every commit —
# the generated-types drift check (Rust API types must match frontend/src/app/
# generated) and the frontend unit tests, so neither can rot. Run in the life dev
# shell. The shared dev-lint custom rules run at COMMIT time for all apps (see
# githooks/pre-commit). Installed by code/kubes/scripts/setup-hooks.sh.
set -euo pipefail

ZERO="0000000000000000000000000000000000000000"
root="$(git rev-parse --show-toplevel)"

# Does this push touch life (across all pushed refs)?
life_changed=0
while read -r _local_ref local_sha _remote_ref remote_sha; do
	[ "$local_sha" = "$ZERO" ] && continue # branch deletion
	if [ "$remote_sha" = "$ZERO" ]; then
		life_changed=1 # new branch — check it
	elif git diff --name-only "$remote_sha..$local_sha" -- code/kubes/life/ 2>/dev/null | grep -q .; then
		life_changed=1
	fi
done

[ "$life_changed" = 1 ] || exit 0

echo "pre-push: life type-drift + frontend tests…" >&2
( cd "$root/code/kubes/life" \
	&& nix develop --command bash -c 'scripts/check-types.sh && (cd frontend && npm test)' )
