#!/usr/bin/env bash
# Pre-commit gate: run the TYPE-AWARE frontend static analysis (typescript-eslint
# recommendedTypeChecked + Angular rules) for any app whose frontend is staged.
# This is deliberately LOCAL-ONLY (not a CI step): type-aware eslint needs the
# full TS program and is slower than a syntactic lint, so the commit is its gate.
#
# Add an app by listing it in APPS (expects `npm run lint` in <app>/frontend).
# Installed by code/kubes/scripts/setup-hooks.sh (symlinked into .git/hooks).
set -euo pipefail

root="$(git rev-parse --show-toplevel)"
APPS="code/kubes/messages"

# Files staged for this commit (added/copied/modified/renamed).
staged="$(git diff --cached --name-only --diff-filter=ACMR)"

for app in $APPS; do
	if printf '%s\n' "$staged" | grep -q "^$app/frontend/"; then
		echo "pre-commit: type-aware lint for $app/frontend…" >&2
		# The TYPE-AWARE tier (lint:types); CI runs the fast `lint`. eslint runs
		# under plain node (no Angular CLI version gate). Fails the commit on any
		# violation.
		( cd "$root/$app/frontend" && nix-shell -p nodejs_24 --run 'npm run lint:types' )
	fi
done
