#!/usr/bin/env bash
# Pre-commit gate: run the shared dev-lint custom rules (~/Code/dev-lint — Python
# ast + ast-grep, e.g. angular-inline-template, DL-ANGULAR-BOUND-STATE-SIGNAL, and
# the Rust rules clippy lacks) on whichever kubes app a commit touches. dev-lint
# is fast (~0.3s) so it gates at commit; it lints the whole app dir (not just
# staged files) because the Angular rule is cross-file (component + template).
# dev-lint is a local flake; if it's missing the hook skips rather than blocking.
# It also runs an app's OWN ast-grep rules if it ships frontend/sgconfig.yml —
# project-specific invariants (e.g. life's single-RxDB rule) that don't belong in
# the shared, generic dev-lint.
#
# Add an app by listing it in APPS and its dev-lint targets in targets_for().
# Installed by code/kubes/scripts/setup-hooks.sh (symlinked into .git/hooks).
set -euo pipefail

dev_lint_dir="$(cd "$(dirname "${BASH_SOURCE[0]}")/../../../../.." && pwd)/dev-lint"
[ -d "$dev_lint_dir" ] || dev_lint_dir="$HOME/Code/dev-lint"
[ -d "$dev_lint_dir" ] || dev_lint_dir="$HOME/code/dev-lint"
DEVLINT="${DEVLINT_DIR:-$dev_lint_dir}"
root="$(git rev-parse --show-toplevel)"
# Empty: every kubes app (coach/home/life/messages/health/fleetwatch/signal) now
# lives in its own repo and runs dev-lint from its own verify.sh. Only k8s
# manifests remain here (linted by ~/Code/check, not this hook). Re-add an app
# here only if its app code moves back in-tree.
APPS=""

# dev-lint target dirs for an app path (empty if unknown). The Android manifest is
# passed as the FILE (not the android/ tree) so the WebView-manifest and
# deploy-script rules run, without dragging gradlew/build into the other walkers.
targets_for() {
	local m="android/app/src/main/AndroidManifest.xml"
	case "$1" in
		# No in-tree apps: each has its own repo now (see APPS above). An app
		# added back would map here, e.g.:
		#   code/kubes/<app>) echo "code/kubes/<app>/frontend/src code/kubes/<app>/src code/kubes/<app>/$m" ;;
		*) echo "" ;;
	esac
}

# Apps with staged changes in this commit.
staged="$(git diff --cached --name-only --diff-filter=ACMR)"

changed=""
for app in $APPS; do
	if printf '%s\n' "$staged" | grep -q "^$app/"; then
		changed="$changed $app"
	fi
done
changed="$(printf '%s\n' $changed | sed '/^$/d')"
[ -n "$changed" ] || exit 0

if [ ! -e "$DEVLINT/flake.nix" ]; then
	echo "pre-commit: dev-lint not found at $DEVLINT — skipping (set DEVLINT_DIR to override)" >&2
	exit 0
fi

cd "$root"
for app in $changed; do
	echo "pre-commit: dev-lint on ${app}…" >&2
	# shellcheck disable=SC2046,SC2086
	nix run "$DEVLINT" -- $(targets_for "$app")
	# App-local ast-grep rules: project-specific invariants the generic dev-lint
	# rules don't cover (e.g. life's single-RxDB rule). Opt-in — an app enables
	# them by adding frontend/sgconfig.yml + ast-grep-rules/.
	if [ -f "$app/frontend/sgconfig.yml" ]; then
		echo "pre-commit: ast-grep local rules on ${app}/frontend…" >&2
		( cd "$app/frontend" && nix run nixpkgs#ast-grep -- scan src )
	fi
done
