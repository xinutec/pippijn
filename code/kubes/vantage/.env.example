# Local dev config for vantage. Copy to .env and `source` it (or use direnv).
# The dev DB comes from scripts/dev-db.sh (127.0.0.1:3307).
export DATABASE_URL=mysql://vantage:vantage@127.0.0.1:3307/vantage
export VANTAGE_TEST_DATABASE_URL=mysql://vantage:vantage@127.0.0.1:3307/vantage
# One or more source:token pairs. In production these come from the k8s secret.
export VANTAGE_TOKENS=mac-mini:dev-token
# Serve the built Angular bundle from here; unset to run API-only behind ng serve.
# export STATIC_DIR=frontend/dist/vantage-web/browser
