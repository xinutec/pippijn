[*.{kt,kts}]
max_line_length = 100
# @Composable functions are PascalCase by Compose convention, not lowerCamelCase.
ktlint_standard_function-naming = disabled
# Wrap signatures only when they exceed the line length, not by parameter count.
ktlint_function_signature_rule_force_multiline_when_parameter_count_greater_or_equal_than = unset
