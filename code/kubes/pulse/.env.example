# Local dev config for pulse. Copy to .env and `source` it (or use direnv).
# The dev DB comes from scripts/dev-db.sh (127.0.0.1:3307).
export DATABASE_URL=mysql://pulse:pulse@127.0.0.1:3307/pulse
export PULSE_TEST_DATABASE_URL=mysql://pulse:pulse@127.0.0.1:3307/pulse
# One or more source:token pairs. In production these come from the k8s secret.
export PULSE_TOKENS=mac-mini:dev-token
# Serve the built Angular bundle from here; unset to run API-only behind ng serve.
# export STATIC_DIR=frontend/dist/pulse-web/browser
