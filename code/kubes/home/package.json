{
  "name": "home-env",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "tsc",
    "start": "node dist/server.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:frontend": "cd frontend && npm test",
    "typecheck": "tsc --noEmit && tsc --noEmit -p tsconfig.test.json",
    "typecheck:frontend": "cd frontend && tsc --noEmit -p tsconfig.app.json",
    "lint": "biome check .",
    "lint:frontend": "cd frontend && npm run lint",
    "format": "biome check --write .",
    "verify": "npm run typecheck && npm run typecheck:frontend && npm run lint && npm run lint:frontend && npm test && npm run test:frontend"
  },
  "dependencies": {
    "@hono/node-server": "^1.13.0",
    "hono": "^4.7.0",
    "kysely": "^0.29.0",
    "kysely-mariadb": "^0.1.2",
    "mariadb": "^3.4.0",
    "zod": "^3.24.0"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.15",
    "@types/node": "^22.0.0",
    "typescript": "^5.7.0",
    "vitest": "^3.2.0"
  },
  "overrides": {
    "esbuild": "^0.28.1"
  }
}
